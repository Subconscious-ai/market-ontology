{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Causal DAG Projection - ontology snapshot to causal artifact",
  "description": "A versioned causal DAG artifact that references market-ontology node IDs. Causal relationships live here, not as graph edges in the core ontology.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_id",
    "causal_dag_projection_version",
    "ontology_snapshot_hash",
    "generated_at",
    "outcome",
    "variables",
    "estimation_target",
    "causal_edges",
    "assumptions",
    "time_series"
  ],
  "properties": {
    "projection_id": {"type": "string"},
    "causal_dag_projection_version": {"type": "string"},
    "ontology_snapshot_hash": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "question": {"type": ["string", "null"]},
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transition"],
      "properties": {
        "transition": {"$ref": "#/$defs/transition_ref"},
        "stakeholder_archetype": {"$ref": "#/$defs/stakeholder_archetype_ref"},
        "description": {"type": ["string", "null"]}
      }
    },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/ontology_variable"}
    },
    "estimation_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_variable_id", "treatment_variable_ids"],
      "properties": {
        "outcome_variable_id": {"type": "string"},
        "treatment_variable_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "effect_modifier_variable_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "control_variable_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        }
      }
    },
    "causal_edges": {
      "type": "array",
      "items": {"$ref": "#/$defs/causal_edge"}
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "time_series": {"$ref": "#/$defs/time_series"},
    "topological_order": {
      "type": "array",
      "items": {"type": "string"}
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "library": {"type": ["string", "null"]},
        "version": {"type": ["string", "null"]}
      }
    }
  },
  "$defs": {
    "ontology_node_type": {
      "type": "string",
      "enum": [
        "Market",
        "Stage",
        "Transition",
        "StakeholderArchetype",
        "Offering",
        "Attribute",
        "AttributeLevel",
        "Trait",
        "TraitLevel",
        "Evidence",
        "Estimate",
        "Company",
        "ExperimentRun"
      ]
    },
    "transition_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "Transition"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "stakeholder_archetype_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "StakeholderArchetype"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "ontology_variable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variable_id",
        "role",
        "estimator_role",
        "ontology_node_type",
        "ontology_node_id",
        "observed_column",
        "value_type"
      ],
      "properties": {
        "variable_id": {"type": "string"},
        "role": {
          "type": "string",
          "enum": ["outcome", "treatment", "context", "moderator", "adjustment"]
        },
        "estimator_role": {
          "type": "string",
          "enum": ["Y", "T", "X", "W", "context", "time_index", "panel_id"]
        },
        "ontology_node_type": {"$ref": "#/$defs/ontology_node_type"},
        "ontology_node_id": {"type": "string"},
        "observed_column": {"type": ["string", "null"]},
        "value_type": {
          "type": "string",
          "enum": ["binary", "categorical", "ordinal", "continuous", "text"]
        },
        "state_space": {
          "type": "array",
          "items": {"type": ["string", "number", "boolean"]}
        },
        "label": {"type": ["string", "null"]}
      }
    },
    "causal_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_variable_id", "target_variable_id", "edge_source"],
      "properties": {
        "source_variable_id": {"type": "string"},
        "target_variable_id": {"type": "string"},
        "edge_source": {
          "type": "string",
          "enum": ["expert", "experiment_design", "causal_discovery", "market_signal", "manual_review"]
        },
        "lag": {"type": ["integer", "null"], "minimum": 0},
        "rationale": {"type": ["string", "null"]},
        "evidence_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "time_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "time_index_column": {"type": ["string", "null"]},
        "panel_id_column": {"type": ["string", "null"]},
        "sampling_interval": {"type": ["string", "null"]},
        "min_lag": {"type": ["integer", "null"], "minimum": 0},
        "max_lag": {"type": ["integer", "null"], "minimum": 0},
        "observation_window": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": {"type": "string", "format": "date-time"},
            "end": {"type": "string", "format": "date-time"}
          }
        }
      }
    }
  }
}
