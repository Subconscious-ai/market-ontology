{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Run Mapping - ontology IDs to SuperEgo/W&B IDs",
  "description": "Deterministic glue between ontology snapshot IDs and run-local SuperEgo/W&B codebook IDs. Ontology inputs must be declared before run-local IDs are mapped.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_run_mapping_version",
    "ontology_snapshot_hash",
    "experiment_run",
    "experiment_inputs",
    "wandb_artifacts",
    "ontology_mappings"
  ],
  "properties": {
    "experiment_run_mapping_version": {"type": "string"},
    "ontology_snapshot_hash": {"type": "string"},
    "experiment_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_run_id"],
      "properties": {
        "experiment_run_id": {"type": "string"},
        "super_ego_run_id": {"type": ["string", "null"]},
        "wandb_entity": {"type": ["string", "null"]},
        "wandb_project": {"type": ["string", "null"]},
        "wandb_run_id": {"type": ["string", "null"]},
        "wandb_run_name": {"type": ["string", "null"]}
      }
    },
    "experiment_inputs": {"$ref": "#/$defs/experiment_inputs"},
    "wandb_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/wandb_artifact_ref"}
    },
    "ontology_mappings": {
      "type": "array",
      "items": {"$ref": "#/$defs/ontology_mapping"}
    },
    "attribute_mappings": {
      "type": "array",
      "items": {"$ref": "#/$defs/attribute_mapping"}
    },
    "level_mappings": {
      "type": "array",
      "items": {"$ref": "#/$defs/level_mapping"}
    },
    "artifact_refs": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "ontology_node_type": {
      "type": "string",
      "enum": [
        "Market",
        "Stage",
        "Transition",
        "StakeholderArchetype",
        "Offering",
        "Attribute",
        "AttributeLevel",
        "Trait",
        "TraitLevel",
        "Evidence",
        "Estimate",
        "Company",
        "ExperimentRun"
      ]
    },
    "ontology_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"$ref": "#/$defs/ontology_node_type"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "transition_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "Transition"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "stakeholder_archetype_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "StakeholderArchetype"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "trait_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "Trait"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "trait_level_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "TraitLevel"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "attribute_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "Attribute"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "attribute_level_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_node_type", "ontology_node_id"],
      "properties": {
        "ontology_node_type": {"const": "AttributeLevel"},
        "ontology_node_id": {"type": "string"}
      }
    },
    "experiment_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependent_variable", "persona", "treatments"],
      "properties": {
        "dependent_variable": {"$ref": "#/$defs/dependent_variable_input"},
        "persona": {"$ref": "#/$defs/persona_input"},
        "treatments": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/treatment_input"}
        },
        "context": {
          "type": "array",
          "items": {"$ref": "#/$defs/ontology_ref"}
        }
      }
    },
    "dependent_variable_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_ref"],
      "properties": {
        "ontology_ref": {"$ref": "#/$defs/transition_ref"},
        "source_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "target_behavior_text": {"type": ["string", "null"]},
        "respondent_dependent_variable_text": {"type": ["string", "null"]}
      }
    },
    "persona_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_ref", "trait_levels"],
      "properties": {
        "ontology_ref": {"$ref": "#/$defs/stakeholder_archetype_ref"},
        "source_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "trait_levels": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/persona_trait_level_input"}
        }
      }
    },
    "persona_trait_level_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trait", "trait_level", "role"],
      "properties": {
        "trait": {"$ref": "#/$defs/trait_ref"},
        "trait_level": {"$ref": "#/$defs/trait_level_ref"},
        "role": {
          "type": "string",
          "enum": ["population_filter", "effect_modifier", "control", "context"]
        },
        "observed_column": {"type": ["string", "null"]},
        "run_local_value": {"type": ["string", "number", "boolean", "null"]},
        "label": {"type": ["string", "null"]}
      }
    },
    "treatment_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attribute", "run_local_attribute_id", "attribute_text", "levels"],
      "properties": {
        "attribute": {"$ref": "#/$defs/attribute_ref"},
        "run_local_attribute_id": {"type": ["string", "integer"]},
        "attribute_text": {"type": "string"},
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/treatment_level_input"}
        }
      }
    },
    "treatment_level_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attribute_level", "run_local_level_id", "level_text"],
      "properties": {
        "attribute_level": {"$ref": "#/$defs/attribute_level_ref"},
        "run_local_level_id": {"type": ["string", "integer"]},
        "level_text": {"type": "string"},
        "is_base_level": {"type": ["boolean", "null"]}
      }
    },
    "wandb_artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity",
        "project",
        "run_id",
        "name",
        "type",
        "version",
        "digest",
        "files"
      ],
      "properties": {
        "entity": {"type": "string"},
        "project": {"type": "string"},
        "run_id": {"type": "string"},
        "name": {"type": "string"},
        "type": {"type": "string"},
        "version": {"type": "string"},
        "digest": {"type": "string"},
        "qualified_name": {"type": ["string", "null"]},
        "aliases": {
          "type": "array",
          "items": {"type": "string"}
        },
        "url": {"type": ["string", "null"]},
        "files": {
          "type": "array",
          "items": {"$ref": "#/$defs/wandb_artifact_file"}
        }
      }
    },
    "wandb_artifact_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {"type": "string"},
        "md5": {"type": ["string", "null"]},
        "size_bytes": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "ontology_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_key",
        "source_system",
        "source_field",
        "run_local_id",
        "ontology_node_type",
        "ontology_node_id",
        "role"
      ],
      "properties": {
        "mapping_key": {
          "type": "string",
          "pattern": "^(super_ego|wandb):[^:]+:.+$",
          "description": "Deterministic key formatted as source_system:source_field:run_local_id."
        },
        "source_system": {
          "type": "string",
          "enum": ["super_ego", "wandb"]
        },
        "source_field": {"type": "string"},
        "run_local_id": {"type": ["string", "integer"]},
        "ontology_node_type": {"$ref": "#/$defs/ontology_node_type"},
        "ontology_node_id": {"type": "string"},
        "role": {
          "type": "string",
          "enum": ["outcome", "population", "treatment", "context", "estimate", "evidence", "artifact"]
        },
        "label": {"type": ["string", "null"]},
        "match_confidence": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0}
      }
    },
    "attribute_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_attribute_id", "super_ego_attribute_id", "attribute_text"],
      "properties": {
        "ontology_attribute_id": {"type": "string"},
        "super_ego_attribute_id": {"type": ["string", "integer"]},
        "attribute_text": {"type": "string"}
      }
    },
    "level_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ontology_attribute_id",
        "ontology_attribute_level_id",
        "super_ego_attribute_id",
        "super_ego_level_id",
        "level_text"
      ],
      "properties": {
        "ontology_attribute_id": {"type": "string"},
        "ontology_attribute_level_id": {"type": "string"},
        "super_ego_attribute_id": {"type": ["string", "integer"]},
        "super_ego_level_id": {"type": ["string", "integer"]},
        "level_text": {"type": "string"},
        "match_confidence": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0}
      }
    }
  }
}
