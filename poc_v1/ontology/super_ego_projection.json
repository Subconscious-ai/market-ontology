{
  "$schema": "https://subconscious.ai/schemas/super-ego-projection-manifest.json",
  "schema_version": "1.4.0",
  "projection_version": "1.0.0",
  "description": "Static integration contract from market-ontology nodes to SuperEgo API surfaces and W&B run/artifact metadata. Credentials are intentionally out of scope.",
  "api": {
    "name": "SuperEgo",
    "base_url": "https://api.subconscious.ai",
    "openapi_url": "https://api.subconscious.ai/openapi.json",
    "openapi_info_version": "1.0.0"
  },
  "wandb": {
    "entity": "why-earth",
    "project": "dev-subconscious-ai",
    "run_id_source": "W&B run name or SuperEgo run_id, depending on the API response surface",
    "credential_policy": "Do not store W&B API keys in this repo or this contract."
  },
  "shared_join_keys": [
    "source_run_id",
    "subconscious_experiment_id",
    "wandb_run_id",
    "ontology_snapshot_hash",
    "ontology_node_type",
    "ontology_node_id"
  ],
  "artifact_contracts": [
    "poc_v1/contracts/causal_dag_projection.schema.json",
    "poc_v1/contracts/experiment_run_mapping.schema.json",
    "poc_v1/contracts/normalized_experiment_results.schema.json",
    "poc_v1/contracts/market_signal.schema.json",
    "poc_v1/contracts/recommendation.schema.json"
  ],
  "ontology_to_super_ego": [
    {
      "ontology_node_type": "Market",
      "super_ego_object": "target_population_context",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/populations/validate"},
        {"method": "POST", "path": "/api/v1/populations/validate-non-us"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/details"}
      ],
      "wandb_surfaces": [
        "run.config.country",
        "run.config.state",
        "run.config.year",
        "run.config.target_population",
        "run.config.population_traits"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Stage",
      "super_ego_object": "journey_stage",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/experiments/dependent-variable"}
      ],
      "wandb_surfaces": [
        "run.config.respondent_dependent_variable",
        "run.config.target_behavior"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Transition",
      "super_ego_object": "target_behavior",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/experiments/dependent-variable"},
        {"method": "POST", "path": "/api/v1/experiments/next-experiment-suggestion"},
        {"method": "POST", "path": "/api/v3/runs/{run_id}/generate/summary"}
      ],
      "wandb_surfaces": [
        "run.config.target_behavior",
        "run.config.target_behavior_context",
        "run.config.respondent_dependent_variable",
        "run.tags"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Company",
      "super_ego_object": "real_world_product_source",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/linkedin-search"},
        {"method": "POST", "path": "/api/v1/market-simulator/check-realworld-product"}
      ],
      "wandb_surfaces": [
        "run.config.realworld_products"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Offering",
      "super_ego_object": "study_subject_or_real_world_product",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/experiments/study-subject"},
        {"method": "POST", "path": "/api/v1/product-attributes-levels"},
        {"method": "POST", "path": "/api/v1/market-simulator/check-realworld-product"}
      ],
      "wandb_surfaces": [
        "run.config.concept_heading",
        "run.config.concept_description",
        "run.config.realworld_products"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Attribute",
      "super_ego_object": "attribute",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/attributes"},
        {"method": "POST", "path": "/api/v1/attributes-levels"},
        {"method": "POST", "path": "/api/v2/attributes_levels/consolidated"},
        {"method": "POST", "path": "/api/v2/attributes_levels/enhance"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/processed/amce"}
      ],
      "wandb_surfaces": [
        "run.config.pre_cooked_attributes_and_levels_lookup",
        "run.config.attribute_count",
        "primary_artifact.experiment_definition",
        "analytics_artifact.amce.Features"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "AttributeLevel",
      "super_ego_object": "attribute_level",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/levels"},
        {"method": "POST", "path": "/api/v1/attributes-levels"},
        {"method": "POST", "path": "/api/v1/attributes-levels/orthogonal"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/processed/amce"}
      ],
      "wandb_surfaces": [
        "run.config.pre_cooked_attributes_and_levels_lookup",
        "run.config.level_count",
        "primary_artifact.experiment_definition",
        "analytics_artifact.amce.Features"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "StakeholderArchetype",
      "super_ego_object": "persona",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/personas"},
        {"method": "GET", "path": "/api/v1/experiments/{run_id}/personas"},
        {"method": "POST", "path": "/api/v1/experiments/personas/stream"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/details"}
      ],
      "wandb_surfaces": [
        "run.config.external_personas",
        "run.config.use_external_personas",
        "run.config.population_traits",
        "primary_artifact.experiment_definition"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Trait",
      "super_ego_object": "trait_or_latent_variable",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/traits"},
        {"method": "POST", "path": "/api/v1/traits/suggest"},
        {"method": "POST", "path": "/api/v1/traits/natural-language"},
        {"method": "POST", "path": "/api/v2/latent-variables/generate"}
      ],
      "wandb_surfaces": [
        "run.config.population_traits",
        "run.config.latent_variables",
        "run.config.latent_variables_traits_count",
        "primary_artifact.experiment_definition"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "TraitLevel",
      "super_ego_object": "trait_level_or_latent_measurement",
      "api_surfaces": [
        {"method": "POST", "path": "/api/v1/traits/suggest/levels"},
        {"method": "POST", "path": "/api/v2/latent-variables/generate-latent-variables-two-step"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/processed/mindset"}
      ],
      "wandb_surfaces": [
        "run.config.population_traits",
        "run.config.levels_per_trait",
        "analytics_artifact.mindset"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id"]
    },
    {
      "ontology_node_type": "Evidence",
      "super_ego_object": "source_artifact_or_extracted_claim",
      "api_surfaces": [
        {"method": "GET", "path": "/api/v3/runs/{run_id}/artifacts"},
        {"method": "GET", "path": "/api/v3/artifacts/{file_name}"},
        {"method": "POST", "path": "/api/v1/aws_s3/presigned-download-url"}
      ],
      "wandb_surfaces": [
        "primary_artifact.experiment_definition",
        "analytics_artifact",
        "run.files"
      ],
      "join_keys": ["source_run_id", "ontology_snapshot_hash", "ontology_node_id", "source_ref"]
    },
    {
      "ontology_node_type": "Estimate",
      "super_ego_object": "amce_or_mindset_estimate",
      "api_surfaces": [
        {"method": "GET", "path": "/api/v3/runs/{run_id}/processed/amce"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/processed/mindset"},
        {"method": "POST", "path": "/api/v1/latent-class-analysis"},
        {"method": "POST", "path": "/api/v1/experiments/rerun-analytics"}
      ],
      "wandb_surfaces": [
        "run.summary",
        "analytics_artifact.amce",
        "analytics_artifact.mindset",
        "run.config.r_squared",
        "run.config.confidence_level"
      ],
      "join_keys": [
        "subconscious_experiment_id",
        "wandb_run_id",
        "ontology_snapshot_hash",
        "ontology_node_id"
      ]
    },
    {
      "ontology_node_type": "ExperimentRun",
      "super_ego_object": "run_and_artifact_lineage",
      "api_surfaces": [
        {"method": "GET", "path": "/api/v3/runs/{run_id}/details"},
        {"method": "GET", "path": "/api/v3/runs/{run_id}/artifacts"},
        {"method": "GET", "path": "/api/v1/runs/{run_id}/status"}
      ],
      "wandb_surfaces": [
        "run.id",
        "run.name",
        "run.displayName",
        "run.config",
        "run.summary",
        "run.artifacts",
        "wandb_artifacts.entity",
        "wandb_artifacts.project",
        "wandb_artifacts.name",
        "wandb_artifacts.type",
        "wandb_artifacts.version",
        "wandb_artifacts.digest",
        "wandb_artifacts.aliases"
      ],
      "join_keys": [
        "subconscious_experiment_id",
        "wandb_run_id",
        "ontology_snapshot_hash",
        "ontology_node_id"
      ]
    }
  ]
}
